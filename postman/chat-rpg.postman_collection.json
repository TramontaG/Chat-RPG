    {
      "name": "Players",
      "item": [
        {
          "name": "Fish",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{masterToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/players/{{playerId}}/actions/fish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "players",
                "{{playerId}}",
                "actions",
                "fish"
              ]
            },
            "description": "Executes the Fishing action for a player. Requires master JWT. The response includes the rolled category, item, quality for fish, fish weight, inventory result, probability modifiers, and progression rewards."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fishing action succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "if (response && response.item && response.item.id) {",
                  "  pm.environment.set('lastFishingItemId', response.item.id);",
                  "}",
                  "",
                  "pm.test('Response contains fishing result', function () {",
                  "  pm.expect(response.action).to.eql('fish');",
                  "  pm.expect(response.category).to.be.oneOf(['fish', 'junk', 'treasure']);",
                  "  pm.expect(response.item).to.have.property('id');",
                  "  pm.expect(response.inventory).to.have.property('added');",
                  "  pm.expect(response.progression).to.have.property('skills');",
                  "});"
                ]
              }
            }
          ]
        }
