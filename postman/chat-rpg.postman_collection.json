{
  "info": {
    "_postman_id": "7d7d2c67-4a95-4d7f-9c8f-4d2a2f4c2d91",
    "name": "Chat RPG API",
    "description": "Collection for the Chat RPG backend. The master user is bootstrapped in the database as `kozz-bot`, and `/auth/login` returns the JWT used by the bot.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Basic healthcheck."
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{masterUsername}}\",\n  \"password\": \"{{masterPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates a user from the database and returns a JWT. For the master, use username `kozz-bot`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.token) {",
                  "  pm.environment.set('masterToken', response.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Players",
      "item": [
        {
          "name": "Fish as master",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{masterToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/players/{{playerId}}/actions/fish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "players",
                "{{playerId}}",
                "actions",
                "fish"
              ]
            },
            "description": "Protected endpoint that executes an action in behalf of a player."
          }
        }
      ]
    }
  ]
}
